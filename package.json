{
  "name": "@tummycrypt/tinyland-activitypub",
  "version": "0.2.2",
  "description": "ActivityPub federation system for Tinyland",
  "type": "module",
  "license": "Zlib AND LicenseRef-Tinyland-Proprietary",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./federation": {
      "types": "./dist/federation/index.d.ts",
      "import": "./dist/federation/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:package": "publint",
    "prepublishOnly": "pnpm build && pnpm check:package"
  },
  "dependencies": {
    "@tummycrypt/tinyland-content-types": "workspace:^"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "publint": "^0.3.18",
    "@tummycrypt/tinyland-content-types": "^0.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinyland-inc/tinyland-activitypub.git"
  },
  "packageManager": "pnpm@10.13.1",
  "homepage": "https://github.com/tinyland-inc/tinyland-activitypub",
  "bugs": {
    "url": "https://github.com/tinyland-inc/tinyland-activitypub/issues"
  }
}